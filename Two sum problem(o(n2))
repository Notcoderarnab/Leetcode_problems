import java.util.*;
class Solution {
    public int[] twoSum(int[] nums, int target) {
        int size=nums.length;
       int[] add=new int[2];
        int count=0;
       for(int i=0;i<size;i++){
         for(int j=i+1;j<size;j++){
            if(nums[i]+nums[j]==target){
                add[count]=i;
                add[count+1]=j;
             return add;
                 
            }
         }
       } 

     return add;
    }
}
